# TickFeed MCP configuration (all optional; sensible defaults shown)
# v1 requires NO exchange API keys — public market data only.

TICKFEED_EXCHANGES=binance,bybit,okx
TICKFEED_DEFAULT_EXCHANGE=binance
TICKFEED_MAX_WATCHED_SYMBOLS=25
TICKFEED_RING_BUFFER_SIZE=1000
TICKFEED_OHLCV_CACHE_PATH=~/.tickfeed/ohlcv.duckdb
TICKFEED_OHLCV_CACHE_TTL_S=60
TICKFEED_REST_RETRIES=3
TICKFEED_SCREEN_CONCURRENCY=5
TICKFEED_TRANSPORT=stdio
TICKFEED_HTTP_HOST=127.0.0.1
TICKFEED_HTTP_PORT=8765
TICKFEED_LOG_LEVEL=INFO
