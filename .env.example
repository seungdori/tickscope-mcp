# Tickscope MCP configuration (all optional; sensible defaults shown)
# v1 requires NO exchange API keys — public market data only.

TICKSCOPE_EXCHANGES=binance,bybit,okx
TICKSCOPE_DEFAULT_EXCHANGE=binance
TICKSCOPE_MAX_WATCHED_SYMBOLS=25
TICKSCOPE_RING_BUFFER_SIZE=1000
TICKSCOPE_OHLCV_CACHE_PATH=~/.tickscope/ohlcv.duckdb
TICKSCOPE_OHLCV_CACHE_TTL_S=60
TICKSCOPE_REST_RETRIES=3
TICKSCOPE_SCREEN_CONCURRENCY=5
TICKSCOPE_TRANSPORT=stdio
TICKSCOPE_HTTP_HOST=127.0.0.1
TICKSCOPE_HTTP_PORT=8765
TICKSCOPE_LOG_LEVEL=INFO
